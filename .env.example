# ============================================
# GUARDIÃ - Template de Configuração
# ============================================
# Copie este arquivo para .env e preencha com suas credenciais reais

# ============================================
# MONGODB ATLAS
# ============================================
MONGODB_URI=mongodb+srv://<usuario>:<senha>@<cluster-url>/?appName=guardia

# ============================================
# GEMINI AI (Google)
# ============================================
GEMINI_API_KEY=sua_chave_gemini_aqui
GEMINI_MODEL=gemini-2.5-flash

# ============================================
# APIs DE BUSCA
# ============================================
# APICPF.com - Consulta de CPF (https://apicpf.com)
APICPF_API_KEY=sua_chave_apicpf_aqui

# CNJ DataJud - Consulta de processos (gratuito)
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==

# ============================================
# AWS CREDENTIALS
# ============================================
AWS_ACCESS_KEY_ID=sua_access_key_aqui
AWS_SECRET_ACCESS_KEY=sua_secret_key_aqui
AWS_REGION=us-east-1

# ============================================
# DATABASE (RDS PostgreSQL)
# ============================================
DATABASE_URL=postgresql://<usuario>:<senha>@<endpoint>:5432/<database>

# ============================================
# AWS S3
# ============================================
S3_BUCKET=guardia-uploads-us-east-1
AWS_S3_BUCKET_ANALYSIS=guardia-uploads-us-east-1

# ============================================
# AWS Cognito
# ============================================
NEXT_PUBLIC_COGNITO_CLIENT_ID=seu_client_id_aqui
NEXT_PUBLIC_COGNITO_USER_POOL_ID=seu_user_pool_id_aqui
COGNITO_CLIENT_SECRET=seu_client_secret_aqui

# ============================================
# AWS SES
# ============================================
SES_SMTP_HOST=smtp.us-east-1.amazonaws.com
SES_SMTP_PORT=587
SES_FROM_EMAIL=contato@guardia.app
SES_ACCESS_KEY_ID=sua_ses_access_key_aqui
SES_SECRET_ACCESS_KEY=sua_ses_secret_key_aqui

# ============================================
# APP CONFIGURATION
# ============================================
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

APP_URL=https://app.guardia.app