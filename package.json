{
  "name": "guardia-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:stable": "WATCHPACK_POLLING=true next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:geo": "tsx scripts/seed-geo.ts",
    "tunnel": "lt --port 3000 --subdomain guardia-dev",
    "dev:tunnel": "concurrently \"npm run dev\" \"npm run tunnel\"",
    "deploy": "bash scripts/deploy.sh",
    "deploy:fast": "bash scripts/deploy.sh --skip-build",
    "setup:alb": "bash scripts/setup-alb.sh",
    "logs": "aws logs tail /ecs/guardia-app --follow --region us-east-1",
    "status": "aws ecs describe-services --cluster guardia-cluster --services guardia-service --region us-east-1 --query 'services[0].{Status:status,Running:runningCount,Desired:desiredCount,Task:taskDefinition}' --output table",
    "url": "echo 'http://guardia-alb-1653604039.us-east-1.elb.amazonaws.com'"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1026.0",
    "@aws-sdk/client-s3": "^3.1025.0",
    "@faker-js/faker": "^10.4.0",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "highlight.js": "^11.11.1",
    "next": "16.2.2",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "biome": "^0.3.3",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "localtunnel": "^2.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
